# =============================================
# 项目环境配置模板
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# .env 文件不会提交到 git（已在 .gitignore 中排除）
# =============================================

# ===== LLM 配置 =====
# API Key（必填，用于 TaskCompletion 的 LLM 评判）
LLM_API_KEY=
# API 基础地址（可选，用于 LiteLLM 代理或自定义端点）
# 例如：http://localhost:6655/litellm/v1
LLM_BASE_URL=
# LLM 模型名称（可选，默认 gpt-4.1）
LLM_MODEL=gpt-4.1

# ===== 数据路径（可选，覆盖默认值）=====
# 评估数据集路径
# EVAL_DATASET_PATH=
# 报告输出目录
# REPORT_OUTPUT_DIR=

# ===== 调试 / 日志（可选）=====
# DEBUG=0
# LOG_LEVEL=INFO